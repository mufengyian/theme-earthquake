---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Fragment slot="head">
    <title th:text="|${singlePage.spec.title} - ${site.title}|"></title>
  </Fragment>

  <section
    id="app"
    class="main detail-sidebar-layout mx-auto flex max-w-7xl flex-col px-4 lg:flex-row"
    th:with="titleOnCover = ${(theme.config.post.title_position ?: 'content') == 'cover' and not #strings.isEmpty(singlePage.spec.cover)}, postDisplay = ${theme.config.post.post_display}"
  >
    <div
      class="content-wrapper post-detail animated fadeIn min-w-0 pt-12 lg:w-3/4 lg:px-8 lg:pb-8 lg:pt-16"
      th:attr="x-data=|Object.assign(upvote('singlepage','content.halo.run','singlepages'), share(${theme.config.post.share_item_ids}), { name: '${singlePage.metadata.name}' })|"
    >
      <div
        th:unless="${titleOnCover}"
        class="flex flex-wrap items-center justify-between gap-2"
      >
        <h1
          class="break-all text-3xl font-bold text-gray-900 dark:text-slate-50"
          th:text="${singlePage.spec.title}"
        >
        </h1>
        <div
          sec:authorize="isAuthenticated()"
          th:attr="x-data=|uiPermission('${#authentication.name}','system:singlepages:manage')|"
        >
          <template x-if="shouldDisplay">
            <a
              th:href="|/console/single-pages/editor?name=${singlePage.metadata.name}&returnToView=true|"
              class="inline-flex size-9 items-center justify-center rounded-full text-gray-500 transition hover:bg-gray-100 hover:text-gray-900 dark:text-slate-400 dark:hover:bg-slate-700 dark:hover:text-slate-100"
              th:title="#{common.edit}"
            >
              <span class="icon-[tabler--edit] text-xl"></span>
            </a>
          </template>
        </div>
      </div>

      <div
        th:if="${postDisplay.visit or postDisplay.publish_time or postDisplay.upvote or haloCommentEnabled or postDisplay.share}"
        class="my-4 flex flex-wrap items-center justify-between gap-4 lg:my-8"
      >
        <div class="flex flex-wrap items-center gap-4">
          <div
            class="inline-flex items-center gap-1.5"
            th:if="${postDisplay.visit} and ${singlePage.stats != null}"
          >
            <div class="icon-[tabler--eye] text-gray-500"></div>
            <span
              class="text-sm font-light text-gray-500 dark:text-slate-400"
              th:text="${singlePage.stats?.visit ?:0}"></span>
          </div>
          <button
            th:if="${postDisplay.upvote}"
            type="button"
            @click="handleUpvote(name)"
            class="inline-flex cursor-pointer items-center gap-1.5 text-gray-500 transition hover:text-red-600 dark:text-slate-400 dark:hover:text-red-400"
          >
            <span class="icon-[tabler--heart]" x-show="!upvoted(name)" x-cloak
            ></span>
            <span
              class="icon-[tabler--heart-filled] text-red-600"
              x-show="upvoted(name)"
              x-cloak></span>
            <span
              class="text-sm font-light"
              th:attr="data-upvote-singlepage-name=${singlePage.metadata.name}"
              th:text="${singlePage.stats?.upvote ?:0}"></span>
          </button>
          <div
            th:if="${haloCommentEnabled}"
            class="inline-flex items-center gap-1.5"
          >
            <div class="icon-[tabler--message-circle] text-gray-500"></div>
            <a
              class="text-sm font-light text-gray-500 hover:text-gray-900 dark:text-slate-400 dark:hover:text-slate-50"
              href="#page-comment"
              th:text="${singlePage.stats?.comment ?:0}"></a>
          </div>
          <button
            th:if="${postDisplay.share}"
            type="button"
            class="inline-flex cursor-pointer items-center gap-1.5 text-gray-500 transition hover:text-green-600 dark:text-slate-400 dark:hover:text-green-400"
            @click="shareModal = true"
          >
            <div class="icon-[tabler--share]"></div>
          </button>
        </div>
        <div
          th:if="${postDisplay.publish_time}"
          class="text-sm font-light text-gray-500 dark:text-slate-400"
          th:title="${singlePage.spec.publishTime}"
          th:text="${#dates.format(singlePage.spec.publishTime,'yyyy-MM-dd')}"
        >
        </div>
      </div>

      <div
        th:unless="${#strings.isEmpty(singlePage.spec.cover)}"
        th:style="|--cover-height: ${theme.config.post.cover_height ?: '24rem'};|"
        class="post-feature-image relative mx-auto my-4 w-full overflow-hidden rounded-lg"
        th:classappend="${titleOnCover ? ' h-[var(--cover-height)]' : ''}"
      >
        <img
          class="w-full"
          th:classappend="${titleOnCover ? ' h-full object-cover' : ' rounded-lg'}"
          th:src="${singlePage.spec.cover}"
          th:alt="${singlePage.spec.title}"
          th:srcset="|${thumbnail.gen(singlePage.spec.cover, 's')} 400w,
                      ${thumbnail.gen(singlePage.spec.cover, 'm')} 800w,
                      ${thumbnail.gen(singlePage.spec.cover, 'l')} 1200w,
                      ${thumbnail.gen(singlePage.spec.cover, 'xl')} 1600w|"
          sizes="(max-width: 1600px) 100vw, 1600px"
          decoding="async"
        />
        <div
          th:if="${titleOnCover}"
          class="absolute inset-0 flex items-end bg-gradient-to-t from-black/70 via-black/20 to-transparent p-5 sm:p-8"
        >
          <h1
            class="break-all text-3xl font-bold text-white drop-shadow"
            th:text="${singlePage.spec.title}"
          >
          </h1>
        </div>
      </div>

      <article
        id="content"
        class="markdown-body !max-w-none break-all py-4"
        th:utext="${singlePage.content.content}"
      >
      </article>

      <div
        id="page-comment"
        class="comment-widget"
        th:if="${haloCommentEnabled}"
      >
        <h2
          class="mb-4 text-lg font-semibold text-gray-900 dark:text-slate-50"
          th:text="#{common.comment}"
        ></h2>
        <halo:comment
          group="content.halo.run"
          kind="SinglePage"
          th:attr="name=${singlePage.metadata.name}"></halo:comment>
      </div>

      <div th:if="${postDisplay.share}">
        <th:block th:replace="~{modules/share-modal}"></th:block>
      </div>
    </div>

    <th:block th:replace="~{modules/sidebar :: sidebar(prepend = null)}"
    ></th:block>
  </section>
</Layout>
