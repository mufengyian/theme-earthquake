<footer class="mt-10 bg-white py-8 dark:bg-slate-800">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <th:block th:replace="~{modules/footer-social}"></th:block>

    <div class="space-y-1">
      <th:block th:if="${theme.config.footer.beian?.show_beian == true}">
        <span
          class="mx-auto block max-w-7xl text-center text-sm text-gray-500 dark:text-slate-300"
          th:if="${not #strings.isEmpty(theme.config.footer.beian?.icp_text)}"
        >
          <a
            href="https://beian.miit.gov.cn/"
            class="hover:underline inline-flex items-center justify-center gap-1"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              th:src="@{/assets/images/icp.webp}"
              class="size-4"
              alt="ICP备案"
              loading="lazy"
              decoding="async"
            />
            <span th:text="${theme.config.footer.beian.icp_text}"></span>
          </a>
        </span>
        <div
          th:if="${not #strings.isEmpty(theme.config.footer.beian?.gongan_text)}"
          class="mx-auto block max-w-7xl text-center text-sm text-gray-500 dark:text-slate-300"
        >
          <p class="flex items-center justify-center gap-1">
            <img
              th:src="@{/assets/images/gongan.png}"
              class="size-4"
              alt="公安备案"
              loading="lazy"
              decoding="async"
            />
            <a
              id="gongan-link"
              href="https://beian.mps.gov.cn/#/query/webSearch"
              class="hover:underline"
              target="_blank"
              rel="noopener noreferrer"
              th:text="${theme.config.footer.beian.gongan_text}"></a>
          </p>
        </div>
      </th:block>
      <div
        class="mx-auto block max-w-7xl text-center text-sm text-gray-500 dark:text-slate-300"
      >
        <div th:if="${theme.config.footer.footer_display?.show_footer_copyright != false}">
          &copy;
          <th:block
            th:text="${#dates.format(new java.util.Date().getTime(), 'yyyy')}"
          ></th:block>
          <a href="/" class="hover:underline" th:text="${site.title}"></a>
        </div>
        <div
          th:if="${theme.config.footer.footer_display?.show_footer_powered_by != false}"
          class="mt-2"
        >
          <span>Powered by</span>
          <a
            class="font-medium text-blue-600 hover:underline dark:text-blue-400"
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.halo.run">Halo</a
          >
          <span>&amp;</span>
          <a
            class="font-medium text-blue-600 hover:underline dark:text-blue-400"
            target="_blank"
            rel="noopener noreferrer"
            href="https://github.com/mufengyian/theme-earthquake">Earthquake</a
          >
        </div>
      </div>
      <span
        th:if="${theme.config.footer.footer_display?.show_halo_footer != false}"
        class="mx-auto block max-w-7xl text-center text-sm text-gray-500 dark:text-slate-300"
      >
        <halo:footer></halo:footer>
      </span>
    </div>
  </div>
</footer>

<script is:inline>
  (function () {
    const link = document.querySelector("#gongan-link");
    if (!link) return;
    const text = link.textContent || "";
    const match = text.match(/\d+/);
    if (match) {
      link.href = "https://beian.mps.gov.cn/#/query/webSearch?code=" + match[0];
    }
  })();
</script>
