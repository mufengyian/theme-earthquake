<footer class="mt-10 bg-white py-8 dark:bg-slate-800">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <th:block th:replace="~{modules/footer-social}"></th:block>

    <div class="space-y-1 text-center text-sm text-gray-500 dark:text-slate-300">
      <th:block th:each="item : ${theme.config.footer.footer_items}">

        <div th:if="${item.value == 'copyright'}">
          &copy;
          <th:block th:text="${#dates.format(new java.util.Date().getTime(), 'yyyy')}"></th:block>
          <a href="/" class="hover:underline" th:text="${site.title}"></a>
        </div>

        <div th:if="${item.value == 'powered_by'}" class="mt-1">
          <span>Powered by</span>
          <a class="font-medium text-blue-600 hover:underline dark:text-blue-400"
             target="_blank" rel="noopener noreferrer"
             href="https://www.halo.run">Halo</a>
          <span>&amp;</span>
          <a class="font-medium text-blue-600 hover:underline dark:text-blue-400"
             target="_blank" rel="noopener noreferrer"
             href="https://github.com/mufengyian/theme-earthquake">Earthquake</a>
        </div>

        <span th:if="${item.value == 'halo_footer'}">
          <halo:footer></halo:footer>
        </span>

        <span th:if="${item.value == 'icp'} and ${not #strings.isEmpty(item.options?.text)}">
          <a href="https://beian.miit.gov.cn/"
             class="hover:underline inline-flex items-center justify-center gap-1"
             target="_blank" rel="noopener noreferrer">
            <img th:src="@{/assets/images/icp.webp}" class="size-4" alt="ICP备案"
                 loading="lazy" decoding="async" />
            <span th:text="${item.options.text}"></span>
          </a>
        </span>

        <div th:if="${item.value == 'gongan'} and ${not #strings.isEmpty(item.options?.text)}">
          <p class="flex items-center justify-center gap-1">
            <img th:src="@{/assets/images/gongan.png}" class="size-4" alt="公安备案"
                 loading="lazy" decoding="async" />
            <a id="gongan-link"
               href="https://beian.mps.gov.cn/#/query/webSearch"
               class="hover:underline"
               target="_blank" rel="noopener noreferrer"
               th:text="${item.options.text}"></a>
          </p>
        </div>

      </th:block>
    </div>
  </div>
</footer>

<script is:inline>
  (function () {
    const link = document.querySelector("#gongan-link");
    if (!link) return;
    const text = link.textContent || "";
    const match = text.match(/\d+/);
    if (match) {
      link.href = "https://beian.mps.gov.cn/#/query/webSearch?code=" + match[0];
    }
  })();
</script>
