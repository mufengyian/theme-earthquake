<meta charset="utf-8" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1, maximum-scale=2"
/>
<meta
  th:if="${theme.config.style.color_scheme_settings?.color_scheme != 'light'}"
  name="theme-color"
  media="(prefers-color-scheme: dark)"
  th:content="${theme.config.style.style_preset == 'earthquake' ? '#0f172a' : '#1e293b'}"
/>
<meta
  th:if="${theme.config.style.color_scheme_settings?.color_scheme != 'dark'}"
  name="theme-color"
  media="(prefers-color-scheme: light)"
  content="#ffffff"
/>
<link
  th:unless="${#strings.isEmpty(site.logo)}"
  rel="preload"
  th:href="${site.logo}"
  as="image"
/>

<!-- SEO: Open Graph (theme.config.seo.enable_og) -->
<th:block th:if="${theme.config.seo?.enable_og}">
<meta property="og:site_name" th:content="${site.title}" />
<meta property="og:title" th:content="${post?.spec?.title ?: page?.spec?.title ?: site.title}" />
<meta
  property="og:description"
  th:content="${post?.status?.excerpt ?: page?.spec?.excerpt ?: site.subtitle ?: ''}"
/>
<meta
  property="og:image"
  th:with="cover = ${post?.spec?.cover ?: page?.spec?.cover ?: site.logo ?: ''}"
  th:unless="${#strings.isEmpty(cover)}"
  th:content="|${site.url}${cover}|"
/>
<meta property="og:type" th:content="${post != null ? 'article' : 'website'}" />
<meta
  property="og:url"
  th:with="permalink = ${post?.status?.permalink ?: page?.status?.permalink ?: '/'}"
  th:content="|${site.url}${permalink}|"
/>
<meta
  th:if="${post?.spec?.publishTime != null}"
  property="article:published_time"
  th:content="${#temporals.format(post.spec.publishTime, 'yyyy-MM-dd''T''HH:mm:ssXXX')}"
/>
<meta
  th:if="${post?.status?.lastModifyTime != null and !#strings.equals(#temporals.format(post.spec.publishTime, 'yyyy-MM-dd''T''HH:mm:ssXXX'), #temporals.format(post.status.lastModifyTime, 'yyyy-MM-dd''T''HH:mm:ssXXX'))}"
  property="article:modified_time"
  th:content="${#temporals.format(post.status.lastModifyTime, 'yyyy-MM-dd''T''HH:mm:ssXXX')}"
/>
</th:block>

<!-- SEO: Twitter Card (theme.config.seo.enable_twitter_card) -->
<th:block th:if="${theme.config.seo?.enable_twitter_card}">
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" th:content="${post?.spec?.title ?: page?.spec?.title ?: site.title}" />
<meta
  name="twitter:description"
  th:content="${post?.status?.excerpt ?: page?.spec?.excerpt ?: site.subtitle ?: ''}"
/>
<meta
  name="twitter:image"
  th:with="cover = ${post?.spec?.cover ?: page?.spec?.cover ?: site.logo ?: ''}"
  th:unless="${#strings.isEmpty(cover)}"
  th:content="|${site.url}${cover}|"
/>
</th:block>

<!-- SEO: Canonical URL (theme.config.seo.enable_canonical) -->
<th:block th:if="${theme.config.seo?.enable_canonical}">
<link
  th:if="${post != null and post.status?.permalink != null}"
  rel="canonical"
  th:href="|${site.url}${post.status.permalink}|"
/>
<link
  th:if="${post == null and page != null and page.status?.permalink != null}"
  rel="canonical"
  th:href="|${site.url}${page.status.permalink}|"
/>
</th:block>

<!-- SEO: JSON-LD Structured Data (theme.config.seo.enable_json_ld) -->
<th:block th:if="${theme.config.seo?.enable_json_ld and post != null}">
<script
  is:inline
  type="application/ld+json"
  th:inline="javascript"
>
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": [[${post.spec.title}]],
  "datePublished": [[${#temporals.format(post.spec.publishTime, 'yyyy-MM-dd''T''HH:mm:ssXXX')}]],
  "dateModified": [[${post.status?.lastModifyTime != null and !#strings.equals(#temporals.format(post.spec.publishTime, 'yyyy-MM-dd''T''HH:mm:ssXXX'), #temporals.format(post.status.lastModifyTime, 'yyyy-MM-dd''T''HH:mm:ssXXX')) ? #temporals.format(post.status.lastModifyTime, 'yyyy-MM-dd''T''HH:mm:ssXXX') : #temporals.format(post.spec.publishTime, 'yyyy-MM-dd''T''HH:mm:ssXXX')}]],
  "author": {
    "@type": "Person",
    "name": [[${site.title}]]
  },
  "publisher": {
    "@type": "Organization",
    "name": [[${site.title}]],
    "logo": {
      "@type": "ImageObject",
      "url": [[${!#strings.isEmpty(site.logo) ? site.url + site.logo : site.url + '/themes/theme-earthquake/assets/images/logo.png'}]]
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": [[${site.url + post.status.permalink}]]
  },
  "image": [[${!#strings.isEmpty(post.spec.cover) ? site.url + post.spec.cover : null}]],
  "description": [[${post.status?.excerpt ?: ''}]]
}
</script>
</th:block>

