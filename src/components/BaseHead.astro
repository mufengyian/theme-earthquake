<!-- Color scheme init: blocking inline script to prevent FOUC -->
<script is:inline th:inline="javascript">
  (function() {
    var scheme = /*[[${theme.config.style.color_scheme_settings?.color_scheme}]]*/ 'system';
    var enableChange = /*[[${theme.config.style.color_scheme_settings?.enable_change_color_scheme}]]*/ false;

    if (enableChange) {
      try {
        var stored = localStorage.getItem('color-scheme');
        if (stored === 'dark' || stored === 'light' || stored === 'system') {
          scheme = stored;
        }
      } catch(e) {}
    }

    var isDark = scheme === 'dark' ||
      (scheme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);

    document.documentElement.classList.add(isDark ? 'dark' : 'light');
    document.documentElement.classList.remove(isDark ? 'light' : 'dark');
  })();
</script>

<script is:inline th:inline="javascript">
  window.i18nResources = {
    "jsModule.colorSchemeSwitcher.dark": `[(#{jsModule.colorSchemeSwitcher.dark})]`,
    "jsModule.colorSchemeSwitcher.light": `[(#{jsModule.colorSchemeSwitcher.light})]`,
    "jsModule.colorSchemeSwitcher.auto": `[(#{jsModule.colorSchemeSwitcher.auto})]`,
    "jsModule.share.qzone": `[(#{jsModule.share.qzone})]`,
    "jsModule.share.weibo": `[(#{jsModule.share.weibo})]`,
    "jsModule.share.douban": `[(#{jsModule.share.douban})]`,
    "jsModule.share.wechat": `[(#{jsModule.share.wechat})]`,
    "jsModule.share.native": `[(#{jsModule.share.native})]`,
    "jsModule.share.windowTitle": `[(#{jsModule.share.windowTitle})]`,
    "jsModule.upvote.networkError": `[(#{jsModule.upvote.networkError})]`,
    "page.photos.photo": `[(#{page.photos.photo})]`,
    "page.photos.download": `[(#{page.photos.download})]`,
    "page.photos.share": `[(#{page.photos.share})]`,
    "page.photos.viewDetail": `[(#{page.photos.viewDetail})]`,
    "page.photos.selectPhoto": `[(#{page.photos.selectPhoto})]`,
  };
  window.colorScheme = /*[[${theme.config.style.color_scheme_settings?.color_scheme}]]*/ "system";
  window.enableChangeColorScheme = /*[[${theme.config.style.color_scheme_settings?.enable_change_color_scheme}]]*/ false;
  window.enableColorSchemeAnimation = /*[[${theme.config.style.color_scheme_settings?.enable_color_scheme_animation}]]*/ false;
</script>
<script>
  import "../assets/main.ts";
  import { initColorScheme } from "../assets/utils/color-scheme";

  const earthWindow = window as Window &
    typeof globalThis & {
      colorScheme: "dark" | "light" | "system";
      enableChangeColorScheme: boolean;
    };

  initColorScheme(earthWindow.colorScheme, earthWindow.enableChangeColorScheme);
</script>
