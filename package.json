{
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "nodemon --config nodemon.json --exec \"astro build && node ./scripts/sanitize-astro-assets.mjs\"",
    "build": "pnpm run build-only && pnpm package",
    "build-only": "astro build && node ./scripts/sanitize-astro-assets.mjs",
    "check": "astro check && pnpm run build-only",
    "format": "prettier --write .",
    "package": "theme-package",
    "prepare": "astro sync"
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "@halo-dev/theme-package-cli": "^1.1.1",
    "@iconify-json/bx": "^1.2.3",
    "@iconify-json/gg": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.86",
    "@iconify-json/tabler": "^1.2.35",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.0.0",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "26.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.8.0",
  "prettier": {
    "plugins": [
      "prettier-plugin-astro"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
